run = "npm install && npx nodemon --signal SIGTERM --quiet server.js"
entrypoint = "server.js"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "node server.js"]

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx nodemon --signal SIGTERM --quiet server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
